# Native build (all variants: build, build-asan, build-tsan, build-gpu, ...)
native/build*/
build/
build-*/
*.o
*.obj
*.a
*.lib
*.exp
*.pdb

# Built plugin artifacts (build from source; not committed).
# Catch the built native plugin under any Plugins/ subtree and every extension
# (.so/.dll/.dylib) plus the Unity-generated .meta sidecars.
**/Runtime/Plugins/**/libUnitedAV.*
unity/Runtime/Plugins/**/*.so
unity/Runtime/Plugins/**/*.so.meta
unity/Runtime/Plugins/**/*.dll
unity/Runtime/Plugins/**/*.dll.meta
unity/Runtime/Plugins/**/*.dylib
unity/Runtime/Plugins/**/*.dylib.meta
unity/Runtime/Plugins/libUnitedAV.so
unity/Runtime/Plugins/libUnitedAV.so.meta

# FFmpeg vendored binaries (provide via build script / release bundle)
native/third_party/ffmpeg/

# Unity
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Ll]ogs/
*.csproj
*.sln
*.user
.vs/
.idea/

# Test media (synthetic, regenerated by tests/media/gen.sh; CC fetch is optional)
tests/media/out/

# Fuzz corpus: the COMMITTED small derived seeds (seed-*) + .gitkeep are kept so
# a fresh checkout reaches the decode loop; the LARGE full-clip copies dropped by
# native/tests/fuzz/gen-corpus.sh (clip-*) mirror the tests/media/out policy —
# regenerated, never committed.
native/tests/fuzz/corpus/*/clip-*

# Streaming server runtime scratch (mediamtx logs, publisher logs)
tests/streaming/run/

# OBS broadcast e2e runtime scratch (per-run OBS config + obs/mediamtx logs)
tests/streaming/run-obs/

# OS
.DS_Store
Thumbs.db

# Packed UPM tarballs (regenerated by `npm pack`)
*.tgz
unity/*.tgz

# libFuzzer artifacts dropped in CWD during fuzz runs (crash/slow/leak repros)
crash-*
leak-*
oom-*
timeout-*
slow-unit-*

# Local Player run dirs / artifacts
.player-*/

# WebGL harness transient serve dir (clip copy, oracle, chromium profile)
tests/web/run*/
tests/web/serve-root/

# nix build symlinks
result
result-*
