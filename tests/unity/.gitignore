# UnitedAV committed test-runner Unity project — ignore all editor-generated,
# machine-local state. Everything here is regenerated by Unity on first open;
# only ProjectSettings/, Packages/manifest.json, and Assets/ are committed.

# Unity-generated, per-machine
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Package manager resolution lock (let each editor resolve org.unitedav via file:)
Packages/packages-lock.json

# Generated IDE/project files
*.csproj
*.sln
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.suo
.vs/
.vscode/
.idea/

# Crash + test artifacts
sysinfo.txt
crashlytics-build.properties
*.apk
*.aab
*.unitypackage

# Test-runner XML output (written by -runTests; keep out of git)
/results*.xml
/test-results*.xml

# OS
.DS_Store
Thumbs.db
